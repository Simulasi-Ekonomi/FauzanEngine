#version 450

layout(local_size_x = 256) in;

layout(std430, binding = 0) buffer Position {
    vec2 pos[];
};

layout(std430, binding = 1) buffer Velocity {
    vec2 vel[];
};

layout(push_constant) uniform Push {
    float dt;
} pushData;

void main()
{
    uint i = gl_GlobalInvocationID.x;

    pos[i] += vel[i] * pushData.dt;
}
